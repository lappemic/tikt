<%= form_with model: client do |f| %>
  <% if client.errors.any? %>
    <div class="flash flash--alert mb-4">
      <strong><%= pluralize(client.errors.count, "error") %> prevented this client from being saved:</strong>
      <ul>
        <% client.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-input", autofocus: true %>
    </div>

    <div class="form-group">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= f.label :phone, class: "form-label" %>
      <%= f.telephone_field :phone, class: "form-input", placeholder: "+41 79 123 45 67" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :address, class: "form-label" %>
    <%= f.text_area :address, class: "form-textarea", rows: 3, placeholder: "Street address, city, state, zip..." %>
    <p class="form-hint">Optional. Will appear on invoices.</p>
  </div>

  <div class="form-group" style="max-width: 200px;">
    <%= f.label :hourly_rate, class: "form-label" %>
    <%= f.number_field :hourly_rate, class: "form-input", step: 0.01, min: 0 %>
    <p class="form-hint">Default rate for new projects.</p>
  </div>

  <fieldset class="form-group" style="border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-4);">
    <legend style="font-weight: 600; font-size: var(--text-sm); padding: 0 var(--space-2);">Portal Access</legend>

    <div class="form-group mb-4">
      <label class="flex flex-center gap-2" style="cursor: pointer;">
        <%= f.check_box :portal_enabled, style: "width: auto;" %>
        <span class="form-label" style="margin-bottom: 0;">Enable client portal</span>
      </label>
      <p class="form-hint">Allow this client to log in and view their projects, time entries, and invoices.</p>
    </div>

    <div class="form-row">
      <div class="form-group">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, class: "form-input", autocomplete: "new-password" %>
        <p class="form-hint">
          <% if client.password_digest.present? %>
            Leave blank to keep current password.
          <% else %>
            Min. 8 characters. Required for portal access.
          <% end %>
        </p>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, class: "form-label" %>
        <%= f.password_field :password_confirmation, class: "form-input", autocomplete: "new-password" %>
      </div>
    </div>
  </fieldset>

  <div class="flex gap-2">
    <%= f.submit class: "btn btn--primary" %>
    <%= link_to "Cancel", clients_path, class: "btn btn--secondary" %>
  </div>
<% end %>
