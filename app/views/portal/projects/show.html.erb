<% content_for(:title) { "#{@project.name} - Tikt" } %>

<div class="page-header">
  <div>
    <h1 class="page-header__title"><%= @project.name %></h1>
    <p class="text-muted">
      <%= project_status_badge(@project) %>
    </p>
  </div>
</div>

<div class="stats mb-8">
  <div class="stat">
    <div class="stat__value"><%= number_with_precision(@project.total_hours, precision: 1) %></div>
    <div class="stat__label">Total Hours</div>
  </div>
  <% if @subprojects.any? %>
    <div class="stat">
      <div class="stat__value"><%= @subprojects.count %></div>
      <div class="stat__label">Subprojects</div>
    </div>
  <% end %>
</div>

<% if @subprojects.any? %>
  <div class="card card--flush mb-6">
    <div class="card__header">
      <h2 class="card__title">Subprojects</h2>
    </div>
    <div class="card__body" style="padding: 0;">
      <div class="table-wrapper">
        <table class="table table--compact">
          <thead>
            <tr>
              <th>Subproject</th>
              <th>Status</th>
              <th class="num">Hours</th>
            </tr>
          </thead>
          <tbody>
            <% @subprojects.each do |sub| %>
              <tr>
                <td><%= sub.name %></td>
                <td><%= project_status_badge(sub) %></td>
                <td class="num"><%= number_with_precision(sub.total_hours, precision: 1) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>

<div class="card card--flush">
  <div class="card__header">
    <h2 class="card__title">Time Entries</h2>
  </div>
  <% if @time_entries.any? %>
    <div class="card__body" style="padding: 0;">
      <div class="table-wrapper">
        <table class="table table--compact">
          <thead>
            <tr>
              <th>Date</th>
              <th>Subproject</th>
              <th>Description</th>
              <th class="num">Hours</th>
            </tr>
          </thead>
          <tbody>
            <% @time_entries.each do |entry| %>
              <tr>
                <td><%= entry.date.strftime("%b %d, %Y") %></td>
                <td><%= entry.subproject&.name || "—" %></td>
                <td><%= entry.description %></td>
                <td class="num"><%= number_with_precision(entry.hours, precision: 2) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="card__body">
      <p class="text-muted">No time entries for this project.</p>
    </div>
  <% end %>
</div>

<p class="mt-6">
  <%= link_to "Back to projects", portal_projects_path %>
</p>
