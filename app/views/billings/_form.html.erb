<%= form_with model: [project, billing], id: "new_billing", class: "form-inline",
    data: { action: "turbo:submit-end->billing-form#reset" } do |f| %>
  <div class="form-group" style="flex: 0 0 130px;">
    <%= f.label :date, class: "form-label" %>
    <%= f.date_field :date, class: "form-input", value: billing.date || Date.current %>
  </div>

  <div class="form-group" style="flex: 0 0 80px;">
    <%= f.label :hours, "Hours", class: "form-label" %>
    <%= f.number_field :hours, class: "form-input", step: 0.25, min: 0.25, placeholder: "0.0",
        data: { "billing-form-target": "hours", action: "input->billing-form#calculateAmount" } %>
  </div>

  <div class="form-group" style="flex: 0 0 120px;">
    <%= f.label :amount, "Amount", class: "form-label" %>
    <%= f.number_field :amount, class: "form-input", step: 0.01, min: 0, placeholder: "0.00",
        data: { "billing-form-target": "amount" } %>
  </div>

  <div class="form-group" style="flex: 2;">
    <%= f.label :note, class: "form-label" %>
    <%= f.text_field :note, class: "form-input", placeholder: "Optional note" %>
  </div>

  <%= f.submit "Record", class: "btn btn--primary" %>
<% end %>
